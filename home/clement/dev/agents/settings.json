{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "env": {
    "_ZO_DOCTOR": "0"
  },
  "permissions": {
    "allow": [
      "Bash(cargo +nightly fmt *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(cargo doc *)",
      "Bash(cargo nextest *)",
      "Bash(cargo search *)",
      "Bash(cargo tree *)",
      "Bash(git show *)",
      "Bash(grep *)",
      "Bash(jj diff *)",
      "Bash(jj file list *)",
      "Bash(jj file show *)",
      "Bash(jj log *)",
      "Bash(jj resolve --list)",
      "Bash(jj show *)",
      "Bash(jj st *)",
      "Bash(jj status *)",
      "Bash(ls *)",
      "Bash(pdftotext *)",
      "Bash(pnpm add *)",
      "Bash(pnpm build *)",
      "Bash(pnpm check *)",
      "Bash(pnpm exec eslint *)",
      "Bash(pnpm exec prettier *)",
      "Bash(pnpm exec slidev *)",
      "Bash(pnpm exec tsc *)",
      "Bash(pnpm format *)",
      "Bash(pnpm format:check *)",
      "Bash(pnpm install)",
      "Bash(pnpm lint *)",
      "Bash(pnpm lint:check *)",
      "Bash(pnpm postinstall)",
      "Bash(pnpm remove *)",
      "Bash(pnpm view *)",
      "Bash(pnpm why *)",
      "Bash(pnpx @tanstack/intent@latest list)",
      "Bash(podman inspect *)",
      "Bash(typst compile *)",
      "Bash(~/.agents/skills/node-dep-source/clone-dep.mjs *)",
      "Bash(~/.claude/skills/node-dep-source/clone-dep.mjs *)",
      "Read(//home/clement/.claude/skills/**)",
      "Read(//tmp/claude-deps/**)",
      "Read(~/.config/AGENTS.md)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:github.com)",
      "WebSearch"
    ],
    "deny": [
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(jj git fetch *)",
      "Bash(jj git push *)",
      "Bash(jj rebase *)",
      "Bash(pnpm approve-builds)",
      "Read(./.env)",
      "Read(./secrets/**)"
    ]
  }
}
