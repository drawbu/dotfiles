{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "acceptEdits",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "env": {
    "_ZO_DOCTOR": "0"
  },
  "voice": {
    "enabled": true,
    "mode": "tap"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "~/.claude/session-context.sh" }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(GIT_CONFIG_GLOBAL=/dev/null git clone *)",
      "Bash(cargo +nightly fmt *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(cargo doc *)",
      "Bash(cargo nextest *)",
      "Bash(cargo search *)",
      "Bash(cargo tree *)",
      "Bash(file *)",
      "Bash(git diff *)",
      "Bash(git ls-remote *)",
      "Bash(git show *)",
      "Bash(grep *)",
      "Bash(hydra-check *)",
      "Bash(jj diff *)",
      "Bash(jj file list *)",
      "Bash(jj file show *)",
      "Bash(jj help *)",
      "Bash(jj log *)",
      "Bash(jj op log *)",
      "Bash(jj resolve --list)",
      "Bash(jj show *)",
      "Bash(jj st *)",
      "Bash(jj status *)",
      "Bash(ls *)",
      "Bash(make *)",
      "Bash(nix build *)",
      "Bash(nix derivation show *)",
      "Bash(nix log *)",
      "Bash(nix search *)",
      "Bash(nix-build *)",
      "Bash(nm *)",
      "Bash(npm --version)",
      "Bash(pdftotext *)",
      "Bash(pnpm --version)",
      "Bash(pnpm add *)",
      "Bash(pnpm audit *)",
      "Bash(pnpm build *)",
      "Bash(pnpm check *)",
      "Bash(pnpm exec eslint *)",
      "Bash(pnpm exec prettier *)",
      "Bash(pnpm exec slidev *)",
      "Bash(pnpm exec tsc *)",
      "Bash(pnpm format *)",
      "Bash(pnpm format:check *)",
      "Bash(pnpm info *)",
      "Bash(pnpm install)",
      "Bash(pnpm link *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm lint:check *)",
      "Bash(pnpm list *)",
      "Bash(pnpm postinstall)",
      "Bash(pnpm remove *)",
      "Bash(pnpm unlink *)",
      "Bash(pnpm view *)",
      "Bash(pnpm why *)",
      "Bash(pnpx @tanstack/intent@latest list)",
      "Bash(pnpx @tanstack/intent@latest load *)",
      "Bash(podman inspect *)",
      "Bash(tar *)",
      "Bash(typst compile *)",
      "Bash(unar *)",
      "Bash(unzip *)",
      "Bash(zip *)",
      "Bash(~/.agents/skills/node-dep-source/clone-dep.ts *)",
      "Bash(~/.claude/skills/node-dep-source/clone-dep.ts *)",
      "Read(./local/**)",
      "Read(//home/clement/.claude/skills/**)",
      "Read(//home/clement/Developer/dotfiles/**)",
      "Read(//home/clement/Developer/nixpkgs/**)",
      "Read(//nix/store/**)",
      "Read(//tmp/**)",
      "Read(//tmp/claude-deps/**)",
      "Read(~/.config/AGENTS.md)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:aur.archlinux.org)",
      "WebFetch(domain:codeberg.org)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:discourse.nixos.org)",
      "WebFetch(domain:docs.jj-vcs.dev)",
      "WebFetch(domain:gcc.gnu.org)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gitlab.archlinux.org)",
      "WebFetch(domain:gitweb.gentoo.org)",
      "WebFetch(domain:hydra.nixos.org)",
      "WebFetch(domain:jj-vcs.github.io)",
      "WebFetch(domain:man.archlinux.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:npmx.dev)",
      "WebFetch(domain:oxc.rs)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:sources.debian.org)",
      "WebFetch(domain:src.fedoraproject.org)",
      "WebSearch",
      "mcp__github__get_commit",
      "mcp__github__get_file_contents",
      "mcp__github__issue_read",
      "mcp__github__list_commits",
      "mcp__github__list_issues",
      "mcp__github__list_pull_requests",
      "mcp__github__pull_request_read",
      "mcp__github__search_code",
      "mcp__github__search_issues",
      "mcp__github__search_pull_requests"
    ],
    "deny": [
      "Bash(apt *)",
      "Bash(apt-cache *)",
      "Bash(dnf *)",
      "Bash(gh *)",
      "Bash(git pull *)",
      "Bash(git push *)",
      "Bash(jj git fetch *)",
      "Bash(jj git push *)",
      "Bash(jj rebase *)",
      "Bash(nix env *)",
      "Bash(nix-env *)",
      "Bash(pnpm approve-builds)",
      "Read(./.env)",
      "Read(./secrets/**)"
    ]
  }
}
